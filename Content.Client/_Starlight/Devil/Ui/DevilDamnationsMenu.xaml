<controls:FancyWindow xmlns="https://spacestation14.io"
                      xmlns:controls="clr-namespace:Content.Client.UserInterface.Controls"
                      xmlns:gfx="clr-namespace:Robust.Client.Graphics;assembly=Robust.Client"
                      Title="{Loc 'devil-damnations-ui-menu-title'}"
                      MinSize="200 100"
                      SetSize="500 600">
    <BoxContainer Orientation="Vertical"
                  VerticalExpand="True">
        <PanelContainer VerticalExpand="True" Margin="10 10 10 10">
            <ScrollContainer HScrollEnabled="False"
                             VerticalExpand="True">
                <BoxContainer Name="DamnationsDisplayContainer"
                              Orientation="Vertical"
                              VerticalExpand="True"
                              Margin="10 10 10 0">
                    <RichTextLabel Text="{Loc 'devil-damnations-ui-menu-text'}"
                                   Name="DamnationsDisplayText"/>
                </BoxContainer>
            </ScrollContainer>
        </PanelContainer>
    </BoxContainer>
</controls:FancyWindow>
