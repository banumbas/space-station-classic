<DefaultWindow
    xmlns="https://spacestation14.io"
    Title="{Loc 'voice-selector-title'}"
    MinSize="450 500"
    SetSize="450 500">
    <BoxContainer
        HorizontalExpand="True"
        Orientation="Vertical"
        SeparationOverride="6"
        VerticalExpand="True">

        <Label Name="CurrentVoiceLabel" />

        <LineEdit Name="SearchLine" PlaceHolder="{Loc 'voice-selector-placeholder'}" />

        <GridContainer Columns="3" HorizontalExpand="True" HSeparationOverride="6" VSeparationOverride="6">
            <OptionButton Name="GenderFilter" HorizontalExpand="True" />
            <OptionButton Name="PitchFilter" HorizontalExpand="True" />
            <OptionButton Name="TagFilter" HorizontalExpand="True" />
        </GridContainer>

        <ScrollContainer VerticalExpand="True">
            <ItemList Name="VoiceList" />
        </ScrollContainer>

        <Button Name="PreviewButton" Text="{Loc 'voice-selector-preview'}" />

    </BoxContainer>
</DefaultWindow>
