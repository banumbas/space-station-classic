<DefaultWindow
    xmlns="https://spacestation14.io"
    xmlns:gfx="clr-namespace:Robust.Client.Graphics;assembly=Robust.Client"
    Title="{Loc 'store-ui-default-title'}"
    MinSize="512 512"
    SetSize="512 512">
    <BoxContainer Orientation="Vertical">
        <BoxContainer Orientation="Vertical" VerticalExpand="True">
            <BoxContainer Margin="4,4,4,4" Orientation="Horizontal">
                <RichTextLabel
                    Name="BalanceInfo"
                    HorizontalAlignment="Left"
                    Access="Public"
                    HorizontalExpand="True" />
                <Button
                    Name="WithdrawButton"
                    MinWidth="64"
                    HorizontalAlignment="Right"
                    Text="{Loc 'store-ui-default-withdraw-text'}" />
                <Button
                    Name="RefundButton"
                    MinWidth="64"
                    HorizontalAlignment="Right"
                    Text="{Loc 'store-ui-refund-text'}" />
                <!--  Starlight  -->
                <Button
                    Name="ToggleViewButton"
                    MinWidth="64"
                    HorizontalAlignment="Right"
                    Text="Grid" />
            </BoxContainer>
            <LineEdit
                Name="SearchBar"
                Margin="4"
                HorizontalExpand="True"
                PlaceHolder="Search" />
            <PanelContainer VerticalExpand="True">
                <PanelContainer.PanelOverride>
                    <gfx:StyleBoxFlat BackgroundColor="#000000FF" />
                </PanelContainer.PanelOverride>
                <BoxContainer Orientation="Horizontal" VerticalExpand="True">
                    <PanelContainer VerticalExpand="True">
                        <PanelContainer.PanelOverride>
                            <gfx:StyleBoxFlat BackgroundColor="#80808005" />
                        </PanelContainer.PanelOverride>
                        <BoxContainer Name="CategoryListContainer" Orientation="Vertical">
                            <!--  Category buttons are added here by code  -->
                        </BoxContainer>
                    </PanelContainer>
                    <ScrollContainer
                        Name="StoreListingsScroll"
                        HScrollEnabled="False"
                        HorizontalExpand="True"
                        MinSize="100 256"
                        SizeFlagsStretchRatio="2"
                        VerticalExpand="True">
                        <BoxContainer
                            Name="StoreListingsContainer"
                            MinSize="100 256"
                            Orientation="Vertical"
                            SizeFlagsStretchRatio="2"
                            VerticalExpand="True">
                            <!--  Listings are added here by code  -->
                        </BoxContainer>
                    </ScrollContainer>
                    <!--  Starlight  -->
                    <ScrollContainer
                        Name="StoreGridScroll"
                        HScrollEnabled="False"
                        HorizontalExpand="True"
                        MinSize="100 256"
                        SizeFlagsStretchRatio="2"
                        VerticalExpand="True"
                        Visible="False">
                        <GridContainer
                            Name="StoreGridContainer"
                            Columns="4"
                            HorizontalExpand="True"
                            MinSize="100 256"
                            SizeFlagsStretchRatio="2"
                            VerticalExpand="True" />
                    </ScrollContainer>
                </BoxContainer>
            </PanelContainer>

            <!--  Starlight  -->

            <PanelContainer
                Name="HoverDivider"
                Margin="0,1,0,1"
                StyleClasses="HighDivider"
                Visible="False" />

            <PanelContainer Name="HoverPreview" MinSize="0 130">
                <PanelContainer.PanelOverride>
                    <gfx:StyleBoxFlat BackgroundColor="#181818" />
                </PanelContainer.PanelOverride>
                <BoxContainer
                    HorizontalExpand="True"
                    Orientation="Vertical"
                    RectClipContent="True"
                    VerticalExpand="False">
                    <Label
                        Name="HoverName"
                        HorizontalExpand="True"
                        RectClipContent="True"
                        StyleClasses="WindowSubtitleText"
                        Text="" />
                    <RichTextLabel
                        Name="HoverDescription"
                        HorizontalExpand="True"
                        RectClipContent="True"
                        Text=""
                        VerticalExpand="False" />
                </BoxContainer>
            </PanelContainer>
        </BoxContainer>

        <!--  Footer  -->
        <BoxContainer Name="TraitorFooter" Orientation="Vertical">
            <PanelContainer StyleClasses="LowDivider" />
            <BoxContainer
                Margin="10,2,5,0"
                VerticalAlignment="Bottom"
                Orientation="Horizontal">
                <Label StyleClasses="WindowFooterText" Text="{Loc 'store-ui-traitor-flavor'}" />
                <Label
                    Margin="0,0,5,0"
                    HorizontalAlignment="Right"
                    HorizontalExpand="True"
                    StyleClasses="WindowFooterText"
                    Text="{Loc 'store-ui-traitor-warning'}" />
            </BoxContainer>
        </BoxContainer>
    </BoxContainer>
</DefaultWindow>
