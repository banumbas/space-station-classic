<Control xmlns="https://spacestation14.io">
    <PanelContainer StyleClasses="BackgroundDark">
        <BoxContainer Orientation="Vertical">
            <ScrollContainer
                HScrollEnabled="False"
                HorizontalExpand="True"
                MinSize="100 100"
                VerticalExpand="True">
                <BoxContainer
                    Name="Notes"
                    Access="Public"
                    Orientation="Vertical" />
            </ScrollContainer>
            <Button
                Name="ShowMoreButton"
                HorizontalAlignment="Center"
                Text="{Loc admin-notes-show-more}"
                Visible="False" />
            <Button
                Name="NewNoteButton"
                Access="Public"
                Disabled="True"
                Text="{Loc admin-notes-new-note}" />
        </BoxContainer>
    </PanelContainer>
</Control>
